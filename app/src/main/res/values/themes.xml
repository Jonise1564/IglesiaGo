<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.IglesiaGo" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/white</item>
        <item name="colorPrimaryVariant">#F5F5F5</item>
        <item name="colorOnPrimary">@color/black</item>

        <item name="colorSecondary">@color/black</item>
        <item name="colorSecondaryVariant">@color/black</item>
        <item name="colorOnSecondary">@color/white</item>

        <item name="android:windowBackground">@color/white</item>
        <item name="android:statusBarColor">@color/white</item>
        <item name="android:windowLightStatusBar">true</item> <item name="colorOnSurface">@color/black</item>
    </style>

    <style name="Theme.IglesiaGo.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.IglesiaGo.AppBarOverlay" parent="ThemeOverlay.AppCompat.Light" />
    <style name="Theme.IglesiaGo.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />
</resources>