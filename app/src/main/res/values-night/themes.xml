<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.IglesiaGo" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#121212</item>
        <item name="colorPrimaryVariant">#000000</item>
        <item name="colorOnPrimary">@color/white</item>

        <item name="colorSecondary">@color/white</item>
        <item name="colorSecondaryVariant">@color/white</item>
        <item name="colorOnSecondary">@color/black</item>

        <item name="android:windowBackground">#121212</item>
        <item name="android:statusBarColor">#121212</item>
        <item name="android:windowLightStatusBar">false</item> <item name="colorOnSurface">@color/white</item>
    </style>

    <style name="Theme.IglesiaGo.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.IglesiaGo.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark" />
    <style name="Theme.IglesiaGo.PopupOverlay" parent="ThemeOverlay.AppCompat.Dark" />
</resources>